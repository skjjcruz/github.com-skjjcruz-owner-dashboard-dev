{
  "name": "fantasy-war-room",
  "version": "1.0.0",
  "description": "Fantasy football owner dashboard — draft war room, earnings tracking, free agent targets",
  "main": "index.html",
  "scripts": {
    "test": "node tests/run.js && npm run test:landing-content && npm run test:regression && npm run test:click-paths && npm run test:intelligence-surfaces && npm run test:draft-context && npm run test:draft-analyst-mock && npm run test:draft-trade-simulator && npm run test:draft-live-sync && npm run test:draft-live-decision && npm run test:draft-recap && npm run test:post-draft-craze && npm run test:draft-strategy-studio && npm run test:ai && npm run test:ai-scale && npm run test:billing && npm run test:security && npm run test:bug-capture && npm run test:analytics && npm run test:tutorial && npm run test:rookies && npm run test:rookie-capital && npm run test:rookie-fields",
    "test:core": "node tests/run.js",
    "test:landing-content": "node tests/landing-content-contract.js",
    "test:regression": "npm run build:preview && node tests/regression.js",
    "test:click-paths": "node tests/click-path-contract.js",
    "test:intelligence-surfaces": "node tests/intelligence-surface-contract.js",
    "test:draft-context": "node tests/draft-context-contract.js",
    "test:draft-analyst-mock": "node tests/draft-analyst-mock.js",
    "test:draft-trade-simulator": "node tests/draft-trade-simulator.js",
    "test:draft-live-sync": "node tests/draft-live-sync.js",
    "test:draft-live-decision": "node tests/draft-live-decision.js",
    "test:draft-recap": "node tests/draft-recap.js",
    "test:post-draft-craze": "node tests/post-draft-craze.js",
    "test:draft-strategy-studio": "node tests/draft-strategy-studio.js",
    "test:ai": "node tests/ai-routing.js",
    "test:ai-scale": "node scripts/ai-scale-load-model.cjs",
    "test:billing": "node tests/billing-schema.js",
    "test:security": "node tests/security-contract.js",
    "test:bug-capture": "node tests/bug-capture.js",
    "test:analytics": "node tests/analytics-report.js",
    "test:tutorial": "node tests/tutorial-contract.js",
    "test:rookies": "node tests/rookie-data.js",
    "test:rookie-capital": "node tests/rookie-capital-monotonicity.js",
    "test:rookie-fields": "node tests/rookie-fields.js",
    "test:browser": "npm run build:preview && node tests/browser-qa.js && node tests/launch-browser-qa.js && node tests/live-click-paths.js && node tests/draft-browser-qa.js && node tests/league-skin-browser-qa.js",
    "test:draft-browser": "npm run build:preview && node tests/draft-browser-qa.js",
    "test:league-skin-browser": "npm run build:preview && node tests/league-skin-browser-qa.js",
    "test:live-click-paths": "npm run build:preview && node tests/live-click-paths.js",
    "test:launch-browser": "npm run build:preview && node tests/launch-browser-qa.js",
    "sync:shared": "node scripts/sync-reconai-shared.cjs",
    "verify:deploy": "node ../reconai/scripts/verify-deploy-readiness.cjs",
    "build:preview": "npm run sync:shared && node scripts/build-preview.cjs",
    "preview:prod": "npm run build:preview && node scripts/serve-static.cjs --port=3002",
    "cap:sync": "npx cap sync",
    "cap:ios": "npx cap open ios",
    "cap:android": "npx cap open android",
    "cap:build:android": "npx cap build android",
    "prepare": "husky || true",
    "start": "npm run sync:shared && node scripts/serve-static.cjs --port=3001 --compile",
    "dev": "npm run sync:shared && node scripts/serve-static.cjs --port=3001 --compile",
    "dev:raw": "npm run sync:shared && node scripts/serve-static.cjs --port=3001",
    "landing:edit": "node scripts/serve-static.cjs --port=3011 --open=landing-editor.html"
  },
  "keywords": [
    "fantasy",
    "football",
    "dashboard"
  ],
  "author": "skjjcruz",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@babel/standalone": "^8.0.4",
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "esbuild": "^0.28.0",
    "terser": "^5.48.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "eslint"
    ]
  }
}
