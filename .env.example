# Local War Room AI preview.
# Copy this file to .env.local and fill in at least one provider key.
# Do not commit .env.local.

# Preferred local dev provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Alternatives
GOOGLE_AI_KEY=
GEMINI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
